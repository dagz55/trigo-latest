// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationType {
  terminal
  custom
}

enum TriderStatus {
  offline
  online
  busy
}

enum RideStatus {
  pending
  accepted
  picked_up
  completed
  cancelled
  waiting_for_trider
}

model Toda {
  id            String   @id @default(uuid())
  name          String
  city          String
  barangay      String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  locations     Location[]
  triders       Trider[]
  queue_items   TriderQueueItem[]
  ride_requests RideRequest[]
}

model Location {
  id         String   @id @default(uuid())
  name       String
  address    String
  latitude   Float
  longitude  Float
  city       String
  barangay   String
  type       String   // terminal or custom
  toda_id    String?
  toda       Toda?    @relation(fields: [toda_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  pickup_requests   RideRequest[] @relation("PickupLocation")
  dropoff_requests  RideRequest[] @relation("DropoffLocation")
}

model Trider {
  id               String   @id @default(uuid())
  user_id          String
  toda_id          String
  toda             Toda     @relation(fields: [toda_id], references: [id])
  first_name       String
  last_name        String
  contact_number   String
  plate_number     String
  license_number   String
  status           String   // offline, online, busy
  current_latitude Float?
  current_longitude Float?
  last_online      DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  queue_items      TriderQueueItem[]
  ride_requests    RideRequest[]
}

model TriderQueueItem {
  id             String   @id @default(uuid())
  trider_id      String
  trider         Trider   @relation(fields: [trider_id], references: [id])
  toda_id        String
  toda           Toda     @relation(fields: [toda_id], references: [id])
  queue_position Int
  joined_at      DateTime @default(now())
}

model RideRequest {
  id                  String    @id @default(uuid())
  booking_code        String    @unique
  passenger_id        String
  toda_id            String
  toda               Toda      @relation(fields: [toda_id], references: [id])
  pickup_location_id  String
  pickup_location     Location  @relation("PickupLocation", fields: [pickup_location_id], references: [id])
  dropoff_location_id String
  dropoff_location    Location  @relation("DropoffLocation", fields: [dropoff_location_id], references: [id])
  status             String    // pending, accepted, picked_up, completed, cancelled
  estimated_fare     Float
  estimated_time     Int
  route_distance     Float?
  route_duration     Float?
  route_geometry     String?
  trider_id          String?
  trider             Trider?   @relation(fields: [trider_id], references: [id])
  created_at         DateTime  @default(now())
  accepted_at        DateTime?
  picked_up_at       DateTime?
  completed_at       DateTime?
  cancelled_at       DateTime?
  cancellation_reason String?
} 